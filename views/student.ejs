<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard</title>
    <link rel="stylesheet" href="/style.css">

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6fb;
            margin: 0;
        }

        .container {
            width: 60%;
            margin: auto;
            padding: 20px;
        }

        .title {
            text-align: center;
            color: #2d4ca3;
            margin-bottom: 20px;
        }

        .section-title {
            color: #2d4ca3;
            margin-top: 30px;
        }

        /* Card */
        .card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0px 4px 12px rgba(0,0,0,0.1);
            margin-bottom: 20px;
        }

        /* Form */
        input, textarea {
            width: 100%;
            padding: 10px;
            margin: 8px 0 16px;
            border-radius: 6px;
            border: 1px solid #ccc;
            background: #e8f0f2;
        }

        .btn-primary {
            background: #2d4ca3;
            color: white;
            padding: 10px 16px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }

        .btn-logout {
            background: #2d4ca3;
            color: white;
            padding: 8px 14px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }

        /* Complaint Card */
        .complaint-card {
            border-left: 6px solid #2d4ca3;
        }

        .card-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .student-id {
            margin: 0;
            font-size: 18px;
            color: #2d4ca3;
        }

        .dept {
            margin: 2px 0;
            font-size: 14px;
            color: #555;
        }

        /* Complaint box */
        .complaint-box {
            background: #f1f5ff;
            padding: 12px;
            border-radius: 8px;
            margin-top: 10px;
        }

        .label {
            font-size: 13px;
            color: #777;
            margin-bottom: 4px;
        }

        .content {
            font-size: 15px;
            font-weight: 500;
        }

        /* Solution */
        .solution-box-new {
            background: #f9fafb;
            padding: 12px;
            border-radius: 8px;
            margin-top: 12px;
        }

        .solution-done {
            color: green;
            font-weight: 500;
        }

        .solution-pending {
            color: orange;
            font-weight: 500;
        }

        /* Badge */
        .badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        .posted {
            background: orange;
            color: white;
        }

        .solved {
            background: green;
            color: white;
        }

    </style>
</head>

<body>

<div class="container">

    <!-- HEADER -->
    <h1 class="title">Post Your Complaint</h1>

    <!-- FORM -->
    <div class="card">
        <form action="/student-save" method="POST">

            <label>Student ID</label>
            <input type="text" name="username"
                value="<%= complaints.length > 0 ? complaints[0].username : '' %>" required>

            <label>Department</label>
            <input type="text" name="dept" required>

            <label>Complaint</label>
            <textarea name="complaint" rows="4" required></textarea>

            <button class="btn-primary" type="submit">Submit Complaint</button>

        </form>
    </div>

    <!-- COMPLAINTS -->
    <h2 class="section-title">Previous Complaints</h2>

    <% complaints.forEach(function(c) { %>

        <div class="card complaint-card">

            <!-- TOP -->
            <div class="card-top">
                <div>
                    <h3 class="student-id">👤 <%= c.username %></h3>
                    <p class="dept">📚 <%= c.dept %></p>
                </div>

                <span class="badge <%= c.status === 'solved' ? 'solved' : 'posted' %>">
                    <%= c.status %>
                </span>
            </div>

            <!-- COMPLAINT -->
            <div class="complaint-box">
                <p class="label">Complaint</p>
                <p class="content"><%= c.complaint %></p>
            </div>

            <!-- SOLUTION -->
            <div class="solution-box-new">
                <p class="label">Solution</p>

                <% if (c.status === 'solved') { %>
                    <p class="solution-done">✔ <%= c.solution %></p>
                <% } else { %>
                    <p class="solution-pending">⏳ Waiting for admin response</p>
                <% } %>

            </div>

        </div>

    <% }) %>

    <!-- LOGOUT -->
    <form action="/logout" method="POST">
        <button class="btn-logout">Logout</button>
    </form>

</div>

</body>
</html>