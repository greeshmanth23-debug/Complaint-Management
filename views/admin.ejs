<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="header">
        <h1>Admin Dashboard</h1>
    </div>
    <div class="body">
        <h2>Welcome, Admin!</h2>
        <p>Here you can manage complaints and view reports.</p>
    </div>
    <div class="body">
        <form action="/admin-save" method="POST">
            <label for="username">Student ID:</label>
            <input type="text" id="username" name="username"><br><br>
            <label for="dept">Department:</label>
            <input type="text" id="dept" name="dept"><br><br>
            <label for="solution">solution:</label><br>
            <textarea id="solution" name="solution" rows="4" cols="50"></textarea><br><br>
            <button type="submit">Submit solution</button>
        </form>
    </div>
    <div class="complaints">
        <h2>Recent Complaints:</h2>
        <ul>
            <% complaints.forEach(function(complaint) { %>
                <li><strong>ID:</strong> <%= complaint.username %> - <strong>Complaint:</strong> <%= complaint.complaint %></li>
            <% }); %> 
        </ul>
        <br>
        <br>
        <form action="/logout" method="POST">
            <button type="submit">Logout</button>
        </form>
    </div>
    

</body>
</html>