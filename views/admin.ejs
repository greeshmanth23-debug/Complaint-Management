<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/style.css">

    <script>
        function fillForm(id, username, dept) {
            document.getElementById('complaintId').value = id;
            document.getElementById('username').value = username;
            document.getElementById('dept').value = dept;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>

    <style>
        .badge {
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 12px;
            margin-left: 10px;
        }
        .posted {
            background: orange;
            color: white;
        }
        .solved {
            background: green;
            color: white;
        }
        .card {
            background: #f5f5f5;
            padding: 10px;
            margin-bottom: 10px;
            border-radius: 8px;
        }
        .solve-btn {
            margin-top: 8px;
            padding: 5px 10px;
            background: #2d6cdf;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <div class="header">
        <h1>Admin Dashboard</h1>
    </div>

    <div class="body">
        <h2>Welcome, Admin!</h2>
        <p>Here you can manage complaints and provide solutions.</p>
    </div>

    <!-- FORM -->
    <div class="body">
        <form action="/admin-save" method="POST">

            <!-- HIDDEN ID -->
            <input type="hidden" id="complaintId" name="complaintId">

            <label>Student ID:</label>
            <input type="text" id="username" name="username" readonly><br><br>

            <label>Department:</label>
            <input type="text" id="dept" name="dept" readonly><br><br>

            <label>Solution:</label><br>
            <textarea id="solution" name="solution" rows="4" cols="50" required></textarea><br><br>

            <button type="submit">Submit Solution</button>
        </form>
    </div>

    <!-- COMPLAINTS -->
    <div class="complaints">
        <h2>Recent Complaints:</h2>

        <% complaints.forEach(function(c) { %>

            <div class="card">

                <strong>ID:</strong> <%= c.username %><br>
                <strong>Department:</strong> <%= c.dept %><br>
                <strong>Complaint:</strong> <%= c.complaint %><br>

                <!-- STATUS BADGE -->
                <span class="badge <%= c.status === 'solved' ? 'solved' : 'posted' %>">
                    <%= c.status %>
                </span>

                <!-- SHOW SOLUTION -->
                <% if (c.status === 'solved') { %>
                    <p><strong>Solution:</strong> <%= c.solution %></p>
                <% } %>

                <!-- SOLVE BUTTON -->
                <% if (c.status !== 'solved') { %>
                    <button class="solve-btn"
                        onclick="fillForm('<%= c._id %>','<%= c.username %>','<%= c.dept %>')">
                        Solve
                    </button>
                <% } %>

            </div>

        <% }) %>

        <br><br>

        <form action="/logout" method="POST">
            <button type="submit">Logout</button>
        </form>

    </div>
</body>
</html>